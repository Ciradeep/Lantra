# ============================================================
# Mother Tongue First AI System — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- Server settings ---
HOST=127.0.0.1
PORT=8001
LOG_LEVEL=info
# Set RELOAD=false in production
RELOAD=true

# --- Bhashini API (optional — production dialectal TTS/STT) ---
# Get your API key at: https://bhashini.gov.in/
# BHASHINI_API_KEY=your_key_here

# --- HuggingFace Token (optional — for private model downloads) ---
# HF_TOKEN=your_huggingface_token

# --- IndicTrans2 settings ---
# Set to true to use IndicTrans2 instead of Google Translate (requires GPU + 2.5GB)
# USE_INDICTRANS2=false
